#!/usr/bin/env bash

if [ "$1" == "-h" ] || [ "$1" == "--help" ]
then
	echo
	echo -e "\e[1;33;1mQUICK CA (`cat $HOME/CA/bin/VERSION`)\e[0m -- [ ca_list_root_issued_certs ]"
	echo
        echo "This utility displays a list of all active certificates issued by the ROOT CA."
        echo
        exit 0
fi


if [ -z $ROOT_CA_PATH ]
then
        echo
        echo -e "\e[1;33;1mQUICK CA (`cat $HOME/CA/bin/VERSION`)\e[0m -- [ ca_list_root_issued_certs ]"
        echo
	echo "ROOT_CA_* environment variable not found."
	echo "Please execute 'source $HOME/CA/setenv.sh'"
	echo
	exit 1
else
	grep -w V $ROOT_CA_PATH/data/index.dat
fi

echo

