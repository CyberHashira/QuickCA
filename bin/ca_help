#!/usr/bin/env bash
echo
echo -e "\e[1;33;1mQUICK CA (`cat $HOME/CA/bin/VERSION`)\e[0m"
echo
echo -e " - ca_about ..................... : \e[1;34mprints information about Quick CA.\e[0m"
echo -e " - ca_examine_cert .............. : \e[1;34mexamine a CA issued certificate.\e[0m"
echo -e " - ca_generate_cert ............. : \e[1;34mgenerates a private key and a signed certificate.\e[0m"
echo -e " - ca_get_ca_chain .............. : \e[1;34mreturns cacert file.\e[0m"
echo -e " - ca_get_root_cert ............. : \e[1;34mreturns your ROOT-CA certificate.\e[0m"
echo -e " - ca_get_issuer_cert ........... : \e[1;34mreturns your ISSUING-CA certificate.\e[0m"
echo -e " - ca_get_issued_cert ........... : \e[1;34mreturns a certified issued by ISSUING-CA.\e[0m"
echo -e " - ca_issue_ca_cert ............. : \e[1;34msigns a certificate request for a CA.\e[0m"
echo -e " - ca_issue_cert ................ : \e[1;34msigns a certificate request.\e[0m"
echo -e " - ca_list_issued_certs ......... : \e[1;34mlists all valid certificates issued by the ISSUING-CA.\e[0m"
echo -e " - ca_list_root_issued_certs .... : \e[1;34mlists all valid certificates issued by the ROOT-CA.\e[0m"
echo -e " - ca_list_revoked_certs ........ : \e[1;34mlists all certificates revoked by the ISSUING-CA.\e[0m"
echo -e " - ca_list_root_revoked_certs ... : \e[1;34mlists all certificates revoked by the ROOT-CA.\e[0m"
echo -e " - ca_revoke_cert ............... : \e[1;34mrevokes an issued certificate.\e[0m"
echo -e " - ca_revoke_root_issued_cert ... : \e[1;34mrevokes a certificate issued by the ROOT CA.\e[0m"
echo -e " - ca_verify_cert ............... : \e[1;34mchecks for the validity of a certificate.\e[0m"
echo -e " - ca_help ...................... : \e[1;34mdisplays this help.\e[0m"
echo


